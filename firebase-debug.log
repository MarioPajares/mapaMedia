[debug] [2026-05-12T20:32:54.954Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/mapamedia-139c1/rulesets {"name":"projects/mapamedia-139c1/rulesets/a20b7a1d-4ac6-4064-b897-4117dd1ce98c","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isGpsWriter() {\n      return request.auth != null && request.auth.uid == 'WLV40U1oCZhiCTwNn41BBp1jZk93';\n    }\n\n    match /latestLocations/{userId} {\n      allow get, list: if userId == 'WLV40U1oCZhiCTwNn41BBp1jZk93';\n      allow create, update, delete: if isGpsWriter() && userId == request.auth.uid;\n    }\n\n    match /gpsPositions/{userId}/samples/{sampleId} {\n      allow read: if isGpsWriter() && userId == request.auth.uid;\n      allow create: if isGpsWriter() && userId == request.auth.uid;\n      allow update, delete: if false;\n    }\n\n    match /raceConfig/current {\n      allow get, list: if true;\n      allow create, update, delete: if isGpsWriter();\n    }\n\n    match /races/{raceId} {\n      allow get, list: if true;\n      allow create, update, delete: if isGpsWriter();\n    }\n\n    match /activeRace/current {\n      allow get, list: if true;\n      allow create, update, delete: if isGpsWriter();\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-12T20:32:54.954623Z","metadata":{"services":["cloud.firestore"]}}
