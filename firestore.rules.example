rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /latestLocations/{userId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn() && userId == request.auth.uid;
    }

    match /gpsPositions/{userId}/samples/{sampleId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create: if isSignedIn() && userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /races/{raceId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /activeRace/current {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
