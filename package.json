{
  "name": "mapa-media",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "cap:sync": "npm run build && cap sync android",
    "cap:copy": "npm run build && cap copy android",
    "cap:open": "cap open android",
    "android:install": "source ~/.nvm/nvm.sh && nvm use 22.19.0 && npm run build && npx cap sync android && cd android && ./gradlew assembleDebug && ./gradlew installDebug",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.10",
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/local-notifications": "^8.0.2",
    "firebase": "^12.12.1",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "@capacitor/cli": "^8.3.1",
    "@types/leaflet": "^1.9.21",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
