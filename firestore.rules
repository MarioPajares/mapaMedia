rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isGpsWriter() {
      return request.auth != null && request.auth.uid == 'WLV40U1oCZhiCTwNn41BBp1jZk93';
    }

    match /latestLocations/{userId} {
      allow get, list: if userId == 'WLV40U1oCZhiCTwNn41BBp1jZk93';
      allow create, update, delete: if isGpsWriter() && userId == request.auth.uid;
    }

    match /gpsPositions/{userId}/samples/{sampleId} {
      allow read: if isGpsWriter() && userId == request.auth.uid;
      allow create: if isGpsWriter() && userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
